```Show moreArchitected Cake Frosting build structure with pragmatic working directory handlingArchitected Cake Frosting build structure with pragmatic working directory handlingHere's a real Cake Frosting build script (Cake Frosting is the C#-console-app flavor of Cake — appropriate here since your script lives in CakeBuild/Program.cs + CakeBuild.csproj, rather than a build.cake script file). This follows the actual API from cakebuild.net / the Cake.Frosting docs.
CakeBuild/CakeBuild.csproj
xml<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>CakeBuild</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Cake.Frosting" Version="4.0.0" />
  </ItemGroup>

</Project>

Note: Directory.Build.props sits at the repo root and will auto-apply to this project too. If you gave every submod a shared TargetFramework/Nullable/etc. in there, make sure those settings are also appropriate for the build tool itself (a net8.0 console exe), or scope those props with a condition (e.g. Condition="'$(MSBuildProjectName)' != 'CakeBuild'") so CakeBuild doesn't inherit mod-specific settings like the VintagestoryAPI reference.

CakeBuild/Program.cs
csharpusing System.Collections.Generic;
using System.Linq;
using Cake.Common.Diagnostics;
using Cake.Common.IO;
using Cake.Common.Tools.DotNet;
using Cake.Common.Tools.DotNet.Build;
using Cake.Core;
using Cake.Core.IO;
using Cake.Frosting;

public static class Program
{
    public static int Main(string[] args)
    {
        return new CakeHost()
            .UseContext<BuildContext>()
            .Run(args);
    }
}

public class BuildContext : FrostingContext
{
    // Repo root is the parent of the CakeBuild project directory.
    public DirectoryPath RootDirectory { get; }
    public DirectoryPath BinDirectory { get; }
    public List<DirectoryPath> ModDirectories { get; set; } = new List<DirectoryPath>();

    public BuildContext(ICakeContext context)
        : base(context)
    {
        // Assumes the build is invoked from the repo root, e.g.:
        //   dotnet run --project CakeBuild -- --target=Default
        RootDirectory = context.Environment.WorkingDirectory;
        BinDirectory = RootDirectory.Combine("bin");
    }
}

[TaskName("Clean")]
public sealed class CleanTask : FrostingTask<BuildContext>
{
    public override void Run(BuildContext context)
    {
        context.CleanDirectory(context.BinDirectory.FullPath);
    }
}

[TaskName("Discover-Mods")]
public sealed class DiscoverModsTask : FrostingTask<BuildContext>
{
    public override void Run(BuildContext context)
    {
        var binPath = context.BinDirectory.FullPath.TrimEnd('/', '\\');

        var modInfoFiles = context.GetFiles(
            context.RootDirectory.FullPath + "/**/modinfo.json");

        context.ModDirectories = modInfoFiles
            .Select(f => f.GetDirectory())
            // Exclude anything already inside bin/ (e.g. previously packaged output)
            .Where(dir => !dir.FullPath.StartsWith(binPath))
            .ToList();

        foreach (var dir in context.ModDirectories)
        {
            context.Information("Found mod: {0}", dir.GetDirectoryName());
        }
    }
}

[TaskName("Build")]
[IsDependentOn(typeof(DiscoverModsTask))]
public sealed class BuildTask : FrostingTask<BuildContext>
{
    public override void Run(BuildContext context)
    {
        foreach (var dir in context.ModDirectories)
        {
            var dirName = dir.GetDirectoryName();
            var csprojFiles = context.GetFiles(dir.FullPath + "/*.csproj");
            var csproj = csprojFiles.FirstOrDefault();

            var packagedDir = context.BinDirectory.Combine(dirName);
            context.EnsureDirectoryExists(packagedDir);

            if (csproj is not null)
            {
                context.Information("Building {0} -> {1}", dirName, packagedDir.FullPath);

                context.DotNetBuild(csproj.FullPath, new DotNetBuildSettings
                {
                    Configuration = "Release",
                    OutputDirectory = packagedDir.FullPath
                });
            }
            else
            {
                context.Information("{0} has no .csproj, skipping compile step.", dirName);
            }
        }
    }
}

[TaskName("Copy-Assets")]
[IsDependentOn(typeof(DiscoverModsTask))]
public sealed class CopyAssetsTask : FrostingTask<BuildContext>
{
    public override void Run(BuildContext context)
    {
        foreach (var dir in context.ModDirectories)
        {
            var dirName = dir.GetDirectoryName();
            var packagedDir = context.BinDirectory.Combine(dirName);
            context.EnsureDirectoryExists(packagedDir);

            var assetsDir = dir.Combine("assets");
            if (context.DirectoryExists(assetsDir.FullPath))
            {
                context.CopyDirectory(assetsDir, packagedDir.Combine("assets"));
            }

            var modInfoFile = dir.CombineWithFilePath("modinfo.json");
            if (context.FileExists(modInfoFile))
            {
                context.CopyFile(modInfoFile, packagedDir.CombineWithFilePath("modinfo.json"));
            }

            var modIconFile = dir.CombineWithFilePath("modicon.png");
            if (context.FileExists(modIconFile))
            {
                context.CopyFile(modIconFile, packagedDir.CombineWithFilePath("modicon.png"));
            }
        }
    }
}

[TaskName("Package")]
[IsDependentOn(typeof(BuildTask))]
[IsDependentOn(typeof(CopyAssetsTask))]
public sealed class PackageTask : FrostingTask<BuildContext>
{
}

[TaskName("Default")]
[IsDependentOn(typeof(CleanTask))]
[IsDependentOn(typeof(PackageTask))]
public sealed class DefaultTask : FrostingTask<BuildContext>
{
}
Notes specific to your tree

biodiversityCrops and expandedFoodiversity have no modinfo.json/README.md-only or missing modinfo.json (biodiversityCrops has neither assets nor modinfo.json in what you pasted) — Discover-Mods will simply skip anything lacking modinfo.json, so biodiversityCrops as shown won't be packaged. Confirm that's intentional or if it's mid-scaffolding.
biodiversityShrubs and biodiversityTrees have assets + modinfo.json but no .csproj/src — these will correctly get an asset-only copy into bin/ with no .dll, matching your original spec.
biodiversityCore has bdCore.csproj — this will compile and land its bdCore.dll in bin/biodiversityCore/.
The **/modinfo.json glob is recursive from root, so it'll also pick up assets/**/modinfo.json if any exist inside asset subfolders (e.g. things like bdaqua/bdflower) — if any of those internal folders happen to contain a stray modinfo.json of their own (some modding frameworks nest them for sub-assets), you'd get false positives. Worth double-checking your assets/ subtrees don't contain another modinfo.json; if they do, tighten the glob to */modinfo.json (one level deep only) instead of **/modinfo.json.

Running it
bashdotnet run --project CakeBuild -- --target=Default
Since BuildContext derives the root from WorkingDirectory, this needs to be invoked from the repo root, not from inside CakeBuild/. If you'd rather make it invocation-order-independent, I can switch RootDirectory to resolve off AppContext.BaseDirectory and walk up until it finds Directory.Build.props — let me know if that's preferable.what should the slnx file look like at the root directory?Architected solution file structure based on directory hierarchyArchitected solution file structure based on directory hierarchyConfirmed the format — .slnx is the newer XML-based solution format (.NET 9 SDK 9.0.200+, VS 17.13+), and it's just <Solution> with <Project Path="..." /> entries, optionally grouped in <Folder> elements. Here's one built for your actual tree:
biodiversity.slnx
xml<Solution>
  <Folder Name="/CakeBuild/">
    <Project Path="CakeBuild/CakeBuild.csproj" />
  </Folder>

  <Folder Name="/Mods/">
    <Project Path="biodiversityCore/bdCore.csproj" />
  </Folder>

  <Folder Name="/Solution Items/">
    <File Path="Directory.Build.props" />
    <File Path="README.md" />
  </Folder>
</Solution>